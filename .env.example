# Slay the Spire Deck Builder - Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# 🔒 NEVER commit .env.local to git - it will contain secrets!

# ============================================================================
# SUPABASE (Database & Auth)
# ============================================================================
# Get these from: https://app.supabase.com → Settings → API

# Project URL (safe to use in frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key - Safe to expose in frontend (JavaScript)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key - KEEP SECRET! Backend only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# FRONTEND (React/Vite)
# ============================================================================

# Backend API URL (where your backend is deployed)
VITE_API_URL=http://localhost:3001

# Environment mode
VITE_ENV=development

# ============================================================================
# BACKEND (Express/Node.js)
# ============================================================================

# Node environment
NODE_ENV=development

# API Port to listen on
API_PORT=3001

# ============================================================================
# DATABASE (Only if using raw PostgreSQL, otherwise use Supabase)
# ============================================================================
# Format: postgresql://user:password@localhost:5432/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/slay-the-spire

# ============================================================================
# INSTRUCTIONS
# ============================================================================
#
# DEVELOPMENT SETUP:
# 1. Copy this file: cp .env.example .env.local
# 2. Find Supabase keys at: https://app.supabase.com → Settings → API
# 3. Replace all placeholder values with your actual keys
# 4. Keep .env.local out of git (already in .gitignore)
# 5. Restart your dev server after changes
#
# PRODUCTION SETUP (Vercel):
# 1. Do NOT create .env.local files
# 2. Go to: Vercel Dashboard → Your Project → Settings → Environment Variables
# 3. Add each variable there (same names and values)
# 4. Vercel automatically injects them at build/runtime
#
# SECURITY NOTES:
# ✅ VITE_ prefixed variables are safe for frontend (bundled in JS)
# ✅ Other variables stay on backend only
# ✅ Never share SUPABASE_SERVICE_ROLE_KEY or DATABASE_URL with anyone
# ✅ Rotate keys if they're ever exposed
# ✅ Use different Supabase projects for dev/prod
#
# FINDING YOUR KEYS:
# Supabase Dashboard:
#   1. Go to https://app.supabase.com
#   2. Select your project
#   3. Go to Settings (gear icon) → API
#   4. Copy the URLs and keys
#
# TESTING:
# Frontend: Values available via import.meta.env.VITE_SUPABASE_URL
# Backend: Values available via process.env.SUPABASE_SERVICE_ROLE_KEY
